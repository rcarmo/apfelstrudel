{
  "name": "apfelstrudel",
  "version": "0.1.0",
  "type": "module",
  "description": "AI-powered live coding music environment with strudel.cc",
  "author": "Rui Carmo",
  "license": "AGPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/rcarmo/apfelstrudel"
  },
  "scripts": {
    "dev": "bun --watch src/server/index.ts",
    "start": "bun src/server/index.ts",
    "build": "bun build src/server/index.ts --outdir=dist --target=bun && cp -r public dist/",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@azure/identity": "^4.13.0",
    "@strudel/codemirror": "^1.3.0",
    "@strudel/draw": "^1.2.6",
    "@strudel/mini": "^1.2.6",
    "@strudel/tonal": "^1.2.6",
    "@strudel/web": "^1.3.0",
    "@strudel/webaudio": "^1.3.0",
    "htm": "^3.1.1",
    "openai": "^4.77.0",
    "preact": "^10.24.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "latest",
    "typescript": "^5.7.2"
  }
}
